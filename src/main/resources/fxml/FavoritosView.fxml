<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mp3.mp3player.view.FavoritosView"
      spacing="10"
      alignment="TOP_CENTER">
    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="btnRemover" text="Remover" styleClass="button-danger" />
        <Button fx:id="btnAtualizar" text="Atualizar" styleClass="button-primary" />
    </HBox>
    <ListView fx:id="listView" VBox.vgrow="ALWAYS" styleClass="list-view" />
    <padding>
        <Insets top="10" right="10" bottom="10" left="10" />
    </padding>
</VBox>