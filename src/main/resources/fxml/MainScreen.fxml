<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mp3.mp3player.view.MainScreen"
      stylesheets="@../css/style.css">
    <VBox fx:id="sidebar" styleClass="sidebar">
        <Button fx:id="btnFavoritos" text="Favoritos" styleClass="sidebar-button" />
        <Button fx:id="btnPlaylists" text="Playlists" styleClass="sidebar-button" />
        <Button fx:id="btnMusicas" text="Músicas" styleClass="sidebar-button" />
        <VBox.margin>
            <Insets top="20" />
        </VBox.margin>
    </VBox>
    <StackPane fx:id="contentArea"
               styleClass="content-area"
               HBox.hgrow="ALWAYS" />
</HBox>