<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mp3.mp3player.view.PlaylistScreen"
      spacing="10"
      alignment="TOP_CENTER">
    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="btnCriar" text="Criar Playlist" styleClass="button-primary" />
        <Button fx:id="btnRemover" text="Remover" styleClass="button-danger" />
        <Button fx:id="btnAtualizar" text="Atualizar" styleClass="button-primary" />
        <Button fx:id="btnVoltar" text="Voltar" styleClass="button-primary" visible="false" managed="false" />
        <Button fx:id="btnAdicionarMusica" text="Adicionar Música" styleClass="button-primary" visible="false" managed="false" />
    </HBox>
    <StackPane VBox.vgrow="ALWAYS">
        <ListView fx:id="listViewPlaylists" styleClass="list-view" />
        <ListView fx:id="listViewMusicas" styleClass="list-view" visible="false" managed="false" />
    </StackPane>
    <padding>
        <Insets top="10" right="10" bottom="10" left="10" />
    </padding>
</VBox>